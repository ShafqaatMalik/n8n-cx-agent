    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst messages = data.messages || [];\nconst humanReplies = messages.filter(msg => !msg.bot_id);\n\nif (humanReplies.length === 0) {\n  return [{\n    json: {\n      action_id: $('Parse Slack Payload').item.json.action_id,\n      ticket_id: $('Parse Slack Payload').item.json.ticket_id,\n      customer_message: $('Parse Slack Payload').item.json.customer_message,\n      human_answer: null\n    }\n  }];\n}\n\nconst latestReply = humanReplies[humanReplies.length - 1];\nreturn [{\n  json: {\n    action_id: $('Parse Slack Payload').item.json.action_id,\n    ticket_id: $('Parse Slack Payload').item.json.ticket_id,\n    customer_message: $('Parse Slack Payload').item.json.customer_message,\n    human_answer: latestReply.text\n  }\n}];"
