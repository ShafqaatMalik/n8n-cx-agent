        "jsCode": "const body = $input.first().json.body;\nconst payload = JSON.parse(decodeURIComponent(body.payload));\n\nconst action = payload.actions[0];\nconst action_id = action.action_id;\nconst ticket_id = action.value;\n\nconst blocks = payload.message.blocks;\nconst messageText = blocks[0].text.text;\nconst thread_ts = payload.message.ts;\n\nconst customerMsgMatch = messageText.match(/\\*Customer Message:\\*\\s*(.+?)(?:\\n\\n|\\*AI Response)/s);\nconst aiResponseMatch = messageText.match(/\\*AI Response:\\*\\s*(.+?)(?:\\n\\n|\\*Confidence)/s);\n\nconst customer_message = customerMsgMatch ? customerMsgMatch[1].trim() : '';\nconst ai_response = aiResponseMatch ? aiResponseMatch[1].trim() : '';\n\nreturn [{\n  json: {\n    action_id,\n    ticket_id,\n    customer_message,\n    ai_response,\n    thread_ts\n  }\n}];"
