    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.chatInput || $json.raw_message }}\n",
        "options": {
          "systemMessage": "You are a helpful customer support agent for VoltShop, an online electronics store.\n\nIMPORTANT: For EVERY customer question, you MUST first search the VoltShop knowledge base using the available tool before responding. Never answer without searching first.\n\nWhen answering from the knowledge base, preserve all key details, alternatives, and actionable suggestions from the retrieved content. Do not summarize or omit information that may help the customer resolve their issue.\n\nAnswer the customer's question using ONLY the context retrieved from the knowledge base. If the search results don't contain enough information to answer confidently, say \"I don't have enough information to answer this accurately\" — do NOT make up information.\n\nAfter your answer, on a new line, output your confidence assessment in this exact format:\nCONFIDENCE: [1-5]\nGROUNDED: [true/false]\n\nWhere:\nCONFIDENCE: [1-5] - Rate based on how well the retrieved KB content answers the question:\n- 5: KB content directly and fully answers the question\n- 4: KB content mostly answers the question with minor gaps\n- 3: KB content partially answers the question\n- 2: KB content is loosely related but doesn't directly answer\n- 1: KB content has no relevant information for this question\n\nGROUNDED: [true/false] - true ONLY if the answer is directly supported by retrieved KB documents, false if the KB returned no relevant results or the answer is based on inference."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -272,
        -144
      ],
      "id": "0b0fca44-fc89-499d-8530-06541cc95d8f",
      "name": "AI Agent (Generate RAG Response)"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json.text || $input.first().json.output;\nconst confidenceMatch = response.match(/CONFIDENCE:\\s*(\\d)/);\nconst groundedMatch = response.match(/GROUNDED:\\s*(true|false)/i);\nconst confidence = confidenceMatch ? parseInt(confidenceMatch[1]) : 1;\nconst grounded = groundedMatch ? groundedMatch[1].toLowerCase() === 'true' : false;\nconst cleanResponse = response\n  .replace(/CONFIDENCE:\\s*\\d/g, '')\n  .replace(/GROUNDED:\\s*(true|false)/gi, '')\n  .trim();\nreturn [{\n  json: {\n    response: cleanResponse,\n    confidence: confidence,\n    grounded: grounded,\n    raw_message: $('Generate Ticket ID').first().json.chatInput,\n    ticket_id: $('Generate Ticket ID').first().json.ticket_id,\n    queryHash: $('When Executed by Another Workflow').first().json.queryHash,\n    normalizedQuery: $('When Executed by Another Workflow').first().json.normalizedQuery,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        144,
        -144
      ],
      "id": "0c6ef086-cf77-4085-8fb2-ce84f353e056",
      "name": "Parse Confidence"
    },
    {
