        "mode": "expression",
        "numberOutputs": 2,
        "output": "={{ $json.grounded === true ? 0 : 1 }}"
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.4,
      "position": [
        416,
        -144
      ],
      "id": "edc583ce-0065-4982-a351-61aae7c6bdce",
      "name": "Route by Confidence"
    },
    {
      "parameters": {
        "jsCode": "const data = {\n  ...$input.first().json,\n  ticket_id: $('Generate Ticket ID').first().json.ticket_id,\n  raw_message: $('Generate Ticket ID').first().json.chatInput,\n  channel: $('Generate Ticket ID').first().json.channel,\n  customer_id: $('Generate Ticket ID').first().json.customer_id,\n  intent: $('Generate Ticket ID').first().json.intent,\n  route: \"escalated\",\n  response_ms: Date.now() - parseInt($('Generate Ticket ID').first().json.ticket_id),\n};\nconst payload = JSON.stringify({\n  channel: \"C0AG97YAYP2\",\n  text: \"Flagged for Review\",\n  blocks: [\n    {\n      type: \"section\",\n      text: {\n        type: \"mrkdwn\",\n        text: `⚠️ *Flagged for Review*\\n\\n*Customer Message:* ${data.raw_message}\\n\\n*AI Response:* ${data.response}\\n\\n*Confidence:* ${data.confidence}/5 | *Grounded:* ${data.grounded}`\n      }\n    },\n    {\n      type: \"actions\",\n      elements: [\n        {\n          type: \"button\",\n          text: { type: \"plain_text\", text: \"✅ Mark Resolved\" },\n          style: \"primary\",\n          action_id: \"mark_resolved\",\n          value: data.ticket_id\n        },\n        {\n          type: \"button\",\n          text: { type: \"plain_text\", text: \"📚 Resolve + Add to KB\" },\n          action_id: \"resolve_add_kb\",\n          value: data.ticket_id\n        }\n      ]\n    }\n  ]\n});\nreturn [{json: {...data, payload, output: data.output}}];"
      },
