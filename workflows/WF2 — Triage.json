      "executeOnce": false,
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "jsCode": "try {\n  const response = $input.first().json.text || $input.first().json.output;\n  const cleaned = response.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  const classification = JSON.parse(cleaned);\n  \n  // Pre-compute route as a simple string\n  let route = 'rag';  // default\n  if (classification.sentiment === 'angry' && classification.urgency === 'critical') {\n    route = 'escalate';\n  } else if (classification.requires_action === true) {\n    route = 'action';\n  }\n\nreturn [{ json: {\n    ...classification,\nmessage: (() => { try { return $('Webhook').first().json.body.chatInput; } catch(e) { return $('When chat message received').first().json.chatInput; } })(),\nraw_message: (() => { try { return $('Webhook').first().json.body.chatInput; } catch(e) { return $('When chat message received').first().json.chatInput; } })(),\n    route: route\n} }];\n} catch (e) {\n  return [{ json: {\n    intent: \"general\",\n    sentiment: \"neutral\",\n    urgency: \"medium\",\n    requires_action: false,\n    reasoning: \"Classification failed — defaulting to safe route\",\n    raw_message: $('When chat message received').first().json.chatInput,\n    route: \"rag\"\n  }}];\n}\n"
      },
